# Copy to .env on the VPS and fill in real values:
#   cp deploy/env.production.example .env

# Your public HTTPS URL (same domain users open in the browser)
PUBLIC_URL=https://your-domain.com
APP_URL=https://your-domain.com

# Strong secrets — change these
JWT_SECRET=replace_with_long_random_string
PGPASSWORD=replace_with_strong_db_password

# Optional: Gemini AI for smart replies
GEMINI_API_KEY=

# WhatsApp Graph API version (optional)
WHATSAPP_API_VERSION=v21.0
