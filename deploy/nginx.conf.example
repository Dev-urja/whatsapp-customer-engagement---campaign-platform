# Nginx site for Urja WhatsApp Platform on subdomain
# Domain: wa.urjagroupofcompany.com
#
# 1. DNS: create A record  wa  →  your VPS public IP
# 2. sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/urja-wa
# 3. sudo ln -sf /etc/nginx/sites-available/urja-wa /etc/nginx/sites-enabled/
# 4. sudo nginx -t && sudo systemctl reload nginx
# 5. sudo certbot --nginx -d wa.urjagroupofcompany.com

server {
    listen 80;
    server_name wa.urjagroupofcompany.com;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}

# After certbot, it will add a listen 443 ssl block automatically.
