# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: Frontend URL for CORS and OAuth callbacks.
APP_URL="http://localhost:3000"

# Database mode: auto | postgres | sqlite
# auto = SQLite fallback when PGPASSWORD is not set; postgres = force PostgreSQL
DB_MODE=postgres

# PostgreSQL connection (local dev defaults)
# Note: if the system service on 5432 uses an unknown password, a user-local
# cluster can run on 5433 — start with pg_ctl and set PGPORT=5433.
PGHOST=localhost
PGPORT=5433
PGDATABASE=urja_whatsapp
PGUSER=postgres
PGPASSWORD=your_postgres_password_here

# JWT secret for auth tokens
JWT_SECRET=change_me_in_production

# PUBLIC_URL: Public HTTPS URL for Meta webhook (production). Often same as deployed app URL.
# Example: https://your-domain.com
PUBLIC_URL="http://localhost:3001"

# WhatsApp Graph API version (optional)
WHATSAPP_API_VERSION=v21.0

# API server port
PORT=3001
